<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TaleWeaver" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Plain teal background only — no icon. The system splash is a brief
         colour flash that fades into the Compose BookCanvas animation. -->
    <style name="Theme.TaleWeaver.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#3D8B9E</item>
        <item name="postSplashScreenTheme">@style/Theme.TaleWeaver</item>
    </style>

</resources>
